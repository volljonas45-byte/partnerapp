# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ── Sicherheit ────────────────────────────────────────────────────────────────
# Langer zufälliger String (mind. 64 Zeichen) — NIEMALS teilen!
# Generator: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=HIER_LANGEN_ZUFAELLIGEN_STRING_EINTRAGEN

# ── Zugelassene E-Mails (Whitelist) ───────────────────────────────────────────
# Kommagetrennt — nur diese E-Mails können sich registrieren
ALLOWED_EMAILS=deine@email.de,partner@email.de

# ── Frontend URL (für CORS) ───────────────────────────────────────────────────
# Deine Vercel-URL, z.B. https://vecturo.vercel.app
FRONTEND_URL=https://deine-app.vercel.app
