# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ── Datenbank (Supabase PostgreSQL) ───────────────────────────────────────────
# Supabase → Settings → Database → Connection String → URI
DATABASE_URL=postgresql://postgres:[PASSWORT]@db.xxxx.supabase.co:5432/postgres

# ── Sicherheit ────────────────────────────────────────────────────────────────
# Langer zufälliger String (mind. 64 Zeichen) — NIEMALS teilen!
# Generator: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=HIER_LANGEN_ZUFAELLIGEN_STRING_EINTRAGEN

# ── Zugelassene E-Mails (Whitelist) ───────────────────────────────────────────
# Kommagetrennt — nur diese E-Mails können sich registrieren
ALLOWED_EMAILS=deine@email.de,partner@email.de

# ── Frontend URL (für CORS) ───────────────────────────────────────────────────
# Deine Vercel-URL, z.B. https://vecturo.vercel.app
FRONTEND_URL=https://deine-app.vercel.app

# ── E-Mail (Gmail SMTP mit App-Passwort) ───────────────────────────────────────
# App-Passwort erstellen: https://myaccount.google.com/apppasswords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=deine@email.de
EMAIL_PASS=xxxx xxxx xxxx xxxx
EMAIL_FROM="Deine Agentur <deine@email.de>"

# ── Frontend-URL für Login-Links in Einladungs-E-Mails ─────────────────────────
APP_URL=https://deine-app.vercel.app

# ── Google Gemini API (kostenlos — für Screenshot-Import) ─────────────────────
# API Key erstellen: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
